{
  "name": "@laravel/passkeys-react",
  "version": "0.0.1",
  "description": "React hooks for Laravel passkey authentication",
  "keywords": [
    "laravel",
    "passkeys",
    "webauthn",
    "react",
    "hooks"
  ],
  "homepage": "https://github.com/laravel/passkeys/tree/main/packages/react#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/laravel/passkeys.git"
  },
  "bugs": {
    "url": "https://github.com/laravel/passkeys/issues"
  },
  "license": "MIT",
  "author": "Laravel",
  "type": "module",
  "main": "dist/index.umd.js",
  "module": "dist/index.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.umd.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@laravel/passkeys": "*"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.1.0",
    "vite-plugin-dts": "^4.5.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  }
}
